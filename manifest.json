{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "SellerRadar - Meesho Seller Growth Extension",
  "description": "Meesho Seller Growth Extension",
  "version": "1.1.10",
  "permissions": [
    "tabs",
    "webNavigation",
    "alarms",
    "activeTab",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "https://www.meesho.com/*",
    "https://meesho.com/*",
    "https://supplier.meesho.com/*"
  ],
  "icons": {
    "128": "/img/icon256.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SellerRadar"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "/img/*"
      ],
      "matches": [
        "https://www.meesho.com/*",
        "https://meesho.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.meesho.com/*",
        "https://meesho.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "/css/common.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://supplier.meesho.com/*"
      ],
      "js": [
        "supplier_content.js"
      ],
      "run_at": "document_end"
    }
  ]
}