{
  "manifest_version": 3,
  "name": "SellerRadar Free - Meesho Seller Tool",
  "description": "Free Meesho Seller Growth Tool - Product analytics, reviews, quality scores & more",
  "version": "2.0.0",
  "permissions": [
    "tabs",
    "webNavigation",
    "alarms",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://www.meesho.com/*",
    "https://meesho.com/*",
    "https://supplier.meesho.com/*"
  ],
  "icons": {
    "128": "img/icon256.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SellerRadar Free"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "img/*"
      ],
      "matches": [
        "https://www.meesho.com/*",
        "https://meesho.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.meesho.com/*",
        "https://meesho.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "css/common.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://supplier.meesho.com/*"
      ],
      "js": [
        "supplier_content.js"
      ],
      "run_at": "document_end"
    }
  ]
}